# SACVPN API — Texas Self-Hosted Environment Variables

# PostgreSQL (local, via docker-compose)
DATABASE_URL=postgresql://sacvpn:CHANGE_ME@sacvpn-db:5432/sacvpn
DB_PASSWORD=CHANGE_ME

# Supabase (auth only — free tier)
SCVPN_SUPABASE_URL=https://ltwuqjmncldopkutiyak.supabase.co
SCVPN_SUPABASE_SERVICE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Legacy price IDs (unused — frontend sends price IDs directly)
# STRIPE_PRICE_PERSONAL=
# STRIPE_PRICE_GAMING=
# STRIPE_PRICE_BUSINESS10=
# STRIPE_PRICE_BUSINESS50=
# STRIPE_PRICE_BUSINESS100=

# SendGrid
SENDGRID_API_KEY=

# SSH (key file mounted via docker-compose volume)
VPN_NODE_SSH_KEY_PATH=/app/ssh/vpn_deploy_key

# App
PORT=3000
NODE_ENV=production
SITE_URL=https://www.sacvpn.com
ALLOWED_ORIGINS=https://www.sacvpn.com,https://sacvpn.com,http://localhost:5173
